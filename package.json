{
  "name": "kiro-rider-light",
  "displayName": "Kiro Rider",
  "description": "Light and dark color themes built for Kiro IDE and VS Code. Consistent syntax highlighting across languages with a themed markdown preview style. Inspired by JetBrains Rider.",
  "version": "0.3.1",
  "publisher": "NikolaiFedorov",
  "repository": {
    "type": "git",
    "url": "https://github.com/Unril/kiro-rider-light"
  },
  "bugs": {
    "url": "https://github.com/Unril/kiro-rider-light/issues"
  },
  "homepage": "https://github.com/Unril/kiro-rider-light",
  "license": "MIT",
  "icon": "img/icon.png",
  "galleryBanner": {
    "color": "#F2F2F2",
    "theme": "light"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Themes"
  ],
  "main": "./src/extension.js",
  "browser": "./src/extension.js",
  "activationEvents": [],
  "keywords": [
    "theme",
    "light",
    "dark",
    "color-theme",
    "rider",
    "jetbrains",
    "kiro",
    "kiro-ide",
    "kotlin",
    "basedpyright",
    "markdown-preview",
    "markdown-style",
    "markdown-theme",
    "syntax-highlighting"
  ],
  "contributes": {
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "./styles/markdown-variables.css",
      "./styles/markdown-preview.css",
      "./styles/markdown-highlight.css"
    ],
    "configuration": {
      "title": "Kiro Rider",
      "properties": {
        "kiro-rider.markdownPreview.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Apply Kiro Rider styling to the Markdown preview. Disable to use the default VS Code preview style."
        }
      }
    },
    "themes": [
      {
        "label": "Kiro Rider Light",
        "uiTheme": "vs",
        "path": "./themes/Kiro Rider Light-color-theme.json"
      },
      {
        "label": "Kiro Rider Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/Kiro Rider Dark-color-theme.json"
      }
    ]
  }
}
